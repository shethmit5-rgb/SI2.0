# SportSync Arena - Backend Configuration Example
# Copy this file to '.env' and fill in your details

# Database and Server Config
MONGO_URI=mongodb://localhost:27017/ArenaSync
JWT_SECRET=your_jwt_secret_here
PORT=5000

# Cloudinary Config (Image/Logo Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Config (OTP & Alerts)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Frontend URL (For CORS and redirection)
FRONTEND_URL=http://localhost:5173

# SMS Gateway Config (Optional)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Payment Config (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Pricing Configs
ORGANIZER_TOURNAMENT_CREATION_FEE=50000
